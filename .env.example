# Copia este archivo a ".env" y completa tus datos reales. No subas ".env" a ningún repositorio.

# Cupos y horario
CUPO_TOTAL=40
HORA_CIERRE=18:00
TZ_NAME=America/Santiago

# Clave secreta para proteger /api/enviar-diario cuando se llama desde un cron externo
# (ej. cron-job.org). Inventa cualquier texto largo y random. Déjalo vacío para desactivar
# la protección en pruebas locales.
CRON_SECRET=

# Correo de destino (empresa de transporte)
MAIL_TO=marcelo.vasquez-externo@angloamerican.com

# Datos SMTP para enviar el correo (ejemplo con Gmail)
# 1. Activa la verificación en 2 pasos en tu cuenta de Gmail.
# 2. Genera una "contraseña de aplicación" en https://myaccount.google.com/apppasswords
# 3. Usa esa contraseña de 16 caracteres en SMTP_PASS (no tu contraseña normal).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=tu-contraseña-de-aplicacion
MAIL_FROM=tu-correo@gmail.com
