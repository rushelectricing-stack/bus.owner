# Copia este archivo a ".env" y completa tus datos reales. No subas ".env" a ningún repositorio.

# Cupos y horario
CUPO_TOTAL=40
HORA_CIERRE=18:00
TZ_NAME=America/Santiago

# Clave secreta para proteger /api/enviar-diario cuando se llama desde un cron externo
# (ej. cron-job.org). Inventa cualquier texto largo y random. Déjalo vacío para desactivar
# la protección en pruebas locales.
CRON_SECRET=

# Correo de destino donde llega el listado diario
MAIL_TO=destino@ejemplo.com

# Envío de correo vía API de Brevo (https://www.brevo.com) — se usa una API HTTP en vez de
# SMTP directo porque varios hosts en la nube (ej. Render) bloquean las conexiones SMTP salientes.
# 1. Crea una cuenta gratis en https://www.brevo.com
# 2. Verifica un correo remitente (Senders, Domains & Dedicated IPs > Senders > Add a sender).
# 3. Genera una API key en SMTP & API > API Keys > Generate a new API key.
MAIL_FROM=tu-correo-verificado@gmail.com
BREVO_API_KEY=tu-api-key-de-brevo
